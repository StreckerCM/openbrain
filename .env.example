# OpenBrain environment configuration
# Copy to .env and fill in values: cp .env.example .env

# Required — OpenAI API key for embedding generation
OPENAI_API_KEY=sk-your-key-here

# Required — PostgreSQL credentials
POSTGRES_DB=openbrain
POSTGRES_USER=openbrain
POSTGRES_PASSWORD=change-me

# Required — PostgREST JWT secret (generate with: openssl rand -hex 32)
PGRST_JWT_SECRET=generate-a-64-char-hex-string
